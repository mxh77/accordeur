{
  "expo": {
    "name": "Accordeur",
    "slug": "accordeur",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a1a2e"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSMicrophoneUsageDescription": "L'accordeur a besoin du microphone pour détecter les notes jouées."
      }
    },
    "android": {
      "package": "com.mxh77.accordeur",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1a1a2e"
      },
      "permissions": ["RECORD_AUDIO"]
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router"
    ],
    "scheme": "accordeur",
    "extra": {
      "eas": {
        "projectId": "1387582a-797e-46ce-98e5-9863e3437d9a"
      }
    }
  }
}
